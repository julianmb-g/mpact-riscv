// Zicfiss and Zicfilp instructions.

instruction group RiscVZicfiss[32] : Inst32Format {
  ssrdp : MopRType : mop_no == 28, rs1 == 0, func1 == 0b1, func2 == 0b00, func4 == 0b0111, func3 == 0b100, opcode == 0b111'0011;
  sspush : MopRRType : mop_no == 7, rs1 == 0, func1h == 0b1, func2 == 0b00, func1l == 0b1, opcode == 0b111'0011;
  lpad : UType : rd == 0, opcode == 0b001'0111;
}
