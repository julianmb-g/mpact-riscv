// This file defines the encoding for the cache block operations in the
// Zicbo extension (Zicbom, Zicboz).

#include "riscv_format32.bin_fmt"

instruction group RiscVZicbo[32] : Inst32Format {
  cbo_inval : IType : imm12 == 0b000000000000, func3 == 0b010, rd == 0b00000, opcode == 0b000'1111;
  cbo_clean : IType : imm12 == 0b000000000001, func3 == 0b010, rd == 0b00000, opcode == 0b000'1111;
  cbo_flush : IType : imm12 == 0b000000000010, func3 == 0b010, rd == 0b00000, opcode == 0b000'1111;
  cbo_zero  : IType : imm12 == 0b000000000100, func3 == 0b010, rd == 0b00000, opcode == 0b000'1111;
}
